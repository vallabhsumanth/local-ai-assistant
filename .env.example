# Copy to .env and fill in when you're ready to use a real LLM.
# With none of these set, JARVIS runs on the built-in "echo" provider.

# One of: echo | anthropic | openai | ollama
JARVIS_LLM_PROVIDER=echo

# Model name for the chosen provider (blank = provider default)
JARVIS_LLM_MODEL=

# API keys (only the one matching your provider is needed)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Ollama (local models)
OLLAMA_HOST=http://localhost:11434

# Optional: better web search (real ranked results + news). Free key at
# https://brave.com/search/api/ . Leave blank to use the keyless fallback.
BRAVE_API_KEY=

# Optional: instant song playback ("play <song>" resolves the exact track).
# Create a free app at https://developer.spotify.com/dashboard and copy the
# Client ID/Secret. Leave blank to use the slower keyless fallback.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# --- Cloud storage (Supabase) ---
# All JARVIS data (conversation history + facts) is stored here, not on disk.
# Find these in your Supabase project: Settings → API.
# Use the service_role key for a personal/server setup (bypasses RLS).
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_KEY=your-service-role-key   # put the REAL key only in .env (never commit it)

# --- Email (Gmail SMTP) — sending always asks you to confirm first ---
# Create an app password: Google Account → Security → App passwords.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-16-char-app-password
EMAIL_FROM=

# Behaviour
JARVIS_LOG_LEVEL=INFO
JARVIS_CONFIRM=1
